{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".oz/hooks/oz-session-init.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".oz/hooks/oz-after-edit.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".oz/hooks/oz-pre-commit.sh",
        "matcher": "git commit",
        "failClosed": true
      },
      {
        "command": ".oz/hooks/oz-shell-rewrite-cursor.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "Read",
        "command": ".oz/hooks/oz-read-rewrite-cursor.sh"
      }
    ],
    "beforeReadFile": [
      {
        "command": ".oz/hooks/oz-read-policy-cursor.sh"
      }
    ]
  }
}
