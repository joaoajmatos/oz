{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".oz/hooks/oz-after-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".oz/hooks/oz-pre-commit.sh"
          },
          {
            "type": "command",
            "command": ".oz/hooks/oz-shell-rewrite.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".oz/hooks/oz-session-init.sh"
          }
        ]
      }
    ]
  }
}
